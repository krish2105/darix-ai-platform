# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's already covered by .gitignore.

# --- Supabase (database + auth) ---------------------------------------
# Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, bypasses Row Level Security. Used by API
# routes to save assessments/leads and to serve shareable report/PDF
# links by id. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) --------------------------------------
RESEND_API_KEY=
# Verified sender address/domain in Resend, e.g. "Darix AI <hello@darix.ai>"
EMAIL_FROM=
# Inbox that receives a copy of every contact-form lead. Leave blank to
# skip the internal alert email (the submitter confirmation still sends).
TEAM_ALERT_EMAIL=

# --- Stripe (payments — test mode until you have a live UAE merchant account) ---
# Dashboard > Developers > API keys. Use the sk_test_... key until you're
# ready to go live, then swap in the sk_live_... key — no code changes needed.
STRIPE_SECRET_KEY=
# Dashboard > Developers > Webhooks > add endpoint for /api/webhooks/stripe,
# then copy its signing secret here (whsec_...).
STRIPE_WEBHOOK_SECRET=

# --- PostHog (analytics) ------------------------------------------------
# Project Settings > Project API Key. This is a public, write-only key —
# safe to expose to the browser (hence NEXT_PUBLIC_).
NEXT_PUBLIC_POSTHOG_KEY=
# Defaults to https://us.i.posthog.com if unset. Use your region's host
# (e.g. https://eu.i.posthog.com) if you created an EU-hosted project.
NEXT_PUBLIC_POSTHOG_HOST=

# --- Cloudflare Turnstile (bot protection on public forms) -------------
# dash.cloudflare.com > Turnstile > add a site for your domain.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Admin ---------------------------------------------------------------
# Comma-separated list of emails allowed to view /admin (leads + all
# assessments). These must be accounts that can sign in via Supabase Auth.
ADMIN_EMAILS=

# --- App ------------------------------------------------------------
# Public base URL of the deployed app, used to build links inside emails
# and Stripe checkout redirects. Example: https://darix.ai
NEXT_PUBLIC_SITE_URL=

# --- Notes on graceful degradation --------------------------------------
# Every integration above is optional at runtime: Resend, Stripe, PostHog,
# and Turnstile all no-op safely when their env vars are unset (see
# isEmailConfigured/isStripeConfigured/isTurnstileConfigured in src/lib).
# Only NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY are required for the core assessment/contact
# flow to actually persist data.
