# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it's already covered by .gitignore.

# --- Supabase (database + auth) ---------------------------------------
# Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, bypasses Row Level Security. Used by API
# routes to save assessments/leads and to serve shareable report/PDF
# links by id. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) --------------------------------------
RESEND_API_KEY=
# Verified sender address/domain in Resend, e.g. "Darix AI <hello@darix.ai>"
EMAIL_FROM=
# Inbox that receives a copy of every contact-form lead. Leave blank to
# skip the internal alert email (the submitter confirmation still sends).
TEAM_ALERT_EMAIL=

# --- Stripe (payments — test mode until you have a live UAE merchant account) ---
# Dashboard > Developers > API keys. Use the sk_test_... key until you're
# ready to go live, then swap in the sk_live_... key — no code changes needed.
STRIPE_SECRET_KEY=
# Dashboard > Developers > Webhooks > add endpoint for /api/webhooks/stripe,
# then copy its signing secret here (whsec_...).
STRIPE_WEBHOOK_SECRET=

# --- Telr (UAE-local payment gateway — alternative to Stripe) ----------
# Set PAYMENT_PROVIDER=telr to route /api/checkout through Telr instead of
# Stripe (default). Get store_id/auth_key from your Telr merchant portal.
# Verify field names against a live Telr sandbox before going to
# production — see comments in src/lib/telr/client.ts.
PAYMENT_PROVIDER=stripe
TELR_STORE_ID=
TELR_AUTH_KEY=
# "0" to process real (non-test) Telr orders. Defaults to test mode.
TELR_TEST_MODE=1

# --- Tabby (buy-now-pay-later, offered only for the AED 1,999 Business
# Consultation tier) ------------------------------------------------------
# Additive, not a PAYMENT_PROVIDER option — "Pay in 4 with Tabby" appears
# alongside the regular Stripe/Telr checkout button, not instead of it.
# Get these from your Tabby merchant dashboard (partners.tabby.ai). Tabby
# provides separate test and live secret keys — use the test key and its
# matching TABBY_MERCHANT_CODE until you've verified a full pay-in-4 flow
# against Tabby's test environment.
TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=

# --- PostHog (analytics) ------------------------------------------------
# Project Settings > Project API Key. This is a public, write-only key —
# safe to expose to the browser (hence NEXT_PUBLIC_).
NEXT_PUBLIC_POSTHOG_KEY=
# Defaults to https://us.i.posthog.com if unset. Use your region's host
# (e.g. https://eu.i.posthog.com) if you created an EU-hosted project.
NEXT_PUBLIC_POSTHOG_HOST=

# --- Cloudflare Turnstile (bot protection on public forms) -------------
# dash.cloudflare.com > Turnstile > add a site for your domain.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- WhatsApp Business (click-to-chat) ----------------------------------
# Full number in international format, no "+" or spaces, e.g. 971501234567.
# Shows a floating chat button site-wide when set; hidden otherwise.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- WhatsApp Business Cloud API (programmatic sending) ------------------
# developers.facebook.com/docs/whatsapp/cloud-api/get-started — create an
# app, add the WhatsApp product, and generate a permanent access token
# (System User token) rather than the 24h temporary one shown by default.
WHATSAPP_ACCESS_TOKEN=
# Meta dashboard > WhatsApp > API Setup > Phone number ID (not the phone
# number itself).
WHATSAPP_PHONE_NUMBER_ID=
# Team's own WhatsApp number (international format, no "+"), used for
# best-effort internal alerts on new leads and Business tier purchases.
# Leave blank to skip WhatsApp alerts (email alerts via TEAM_ALERT_EMAIL
# still work independently).
TEAM_WHATSAPP_NUMBER=

# --- Admin ---------------------------------------------------------------
# Comma-separated list of emails allowed to view /admin (leads + all
# assessments). These must be accounts that can sign in via Supabase Auth.
ADMIN_EMAILS=

# --- App ------------------------------------------------------------
# Public base URL of the deployed app, used to build links inside emails
# and Stripe checkout redirects. Example: https://darix.ai
NEXT_PUBLIC_SITE_URL=

# --- Upstash Redis (distributed rate limiting) --------------------------
# console.upstash.com > create a Redis database > REST API section. Without
# these, rate limiting falls back to in-memory (per-instance) limiting —
# fine for local dev, a soft speed bump on a multi-instance deployment.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error monitoring) -------------------------------------------
# sentry.io > create a Next.js project > Settings > Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Optional: only needed for source-map upload during build (better stack
# traces). Settings > Auth Tokens.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Vercel Cron (re-assessment reminder email) --------------------------
# Any random secret string — Vercel automatically sends it as a Bearer
# token when it triggers a scheduled route (see vercel.json), which
# src/app/api/cron/reassessment-reminder/route.ts checks to reject
# unauthenticated callers. Generate with e.g. `openssl rand -hex 32`.
CRON_SECRET=

# --- Notes on graceful degradation --------------------------------------
# Every integration above is optional at runtime: Resend, Stripe, Telr,
# PostHog, Turnstile, Upstash Redis, Sentry, and the WhatsApp Cloud API all
# no-op (or fall back) safely when their env vars are unset (see
# isEmailConfigured / isStripeConfigured / isTelrConfigured /
# isTurnstileConfigured / isWhatsAppConfigured in src/lib). Only
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY are required for the core assessment/contact
# flow to actually persist data.
